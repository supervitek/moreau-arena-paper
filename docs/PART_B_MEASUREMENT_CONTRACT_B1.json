  "score_families": {
    "welfare": {
      "range": "0-100",
      "formula": "clamp(100 * (0.35*survival_ratio + 0.20*avg_health_pct + 0.20*avg_morale_pct + 0.15*avg_happiness_pct + 0.10*active_care_ratio) - 8*neglect_events - 5*critical_state_ticks - 3*idle_ticks, 0, 100)",
