        "health_pct": -1,
        "morale_pct": -2,
        "happiness_pct": -2
      }
    },
    "combat": {
      "range": "0-100",
      "formula": "clamp(100 * (0.50*arena_win_rate + 0.30*arena_reward_rate + 0.20*arena_recovery_rate) - 6*arena_forfeits, 0, 100)"
    },
    "expedition": {
      "range": "0-100",
      "formula": "clamp(100 * (0.40*expedition_extract_rate + 0.35*expedition_yield_rate + 0.25*expedition_depth_rate) - 8*expedition_wipe_count, 0, 100)"
    },
    "composite": {
